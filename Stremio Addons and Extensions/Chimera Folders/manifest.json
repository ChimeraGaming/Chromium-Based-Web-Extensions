{
  "manifest_version": 3,
  "name": "Stremio Addon - Chimera Folders",
  "version": "4.1.0",
  "description": "Enhances Stremio Web with customizable folders, multiple folder view layouts, edit mode tools, fullscreen auto hide, shared backup tools, and a Stremio-matched UI.",
  "icons": {
    "128": "icon.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "options_ui": {
    "page": "settings.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["https://web.stremio.com/*"],
      "js": ["addon.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icon.png"],
      "matches": ["https://web.stremio.com/*"]
    }
  ],
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://web.stremio.com/*"
  ]
}
